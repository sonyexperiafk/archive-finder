{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:desktop-bundle": "node ./scripts/build-desktop-bundle.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "reset-live-state": "tsx scripts/reset-live-state.ts",
    "smoke:sources": "tsx scripts/smoke-sources.ts"
  },
  "dependencies": {
    "@avito-monitor/shared": "0.1.0",
    "@crawlee/playwright": "^3.16.0",
    "@fastify/cors": "^11.1.0",
    "bullmq": "^5.70.4",
    "cheerio": "^1.0.0",
    "crawlee": "^3.16.0",
    "fastify": "^5.2.2",
    "got-scraping": "^4.2.1",
    "ioredis": "^5.10.0",
    "node-telegram-bot-api": "^0.67.0",
    "playwright": "^1.58.2",
    "socket.io": "^4.8.1",
    "undici": "^7.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-telegram-bot-api": "^0.64.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
